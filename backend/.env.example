PORT=3001

# ─── INFRA COMPARTILHADA (uma vez, do sistema) ────────────────────────────────

# ID do tenant padrão (single-tenant). Em multi-tenant, remover — sistema resolve pelo banco.
TENANT_ID=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# OpenAI (embeddings + LLM)
OPENAI_API_KEY=

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Mega API (WhatsApp — infra compartilhada, uma instância por tenant no painel)
MEGAAPI_HOST=https://apinocode02.megaapi.com.br
MEGAAPI_INSTANCE_KEY=
MEGAAPI_TOKEN=

# Chatwoot (orquestrador central)
CHATWOOT_API_URL=
CHATWOOT_API_KEY=
CHATWOOT_ACCOUNT_ID=

# Telegram (alertas de infra — não é por tenant)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ─── POR TENANT (gerenciado pelo painel admin → tabela tenant_config) ─────────
# Os valores abaixo são apenas para desenvolvimento local com UM tenant.
# Em produção multi-tenant, cada cliente tem suas chaves no banco (tenant_config).

# RAG manual → tenant_config key: rag.content
# Notion (leads opcional) → tenant_config keys: notion.leads_enabled, notion.token, notion.leads_database_id
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=

# Google Calendar → tenant_config keys: gcal.client_id, gcal.refresh_token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Nexfit → tenant_config key: nexfit.api_key
NEXFIT_API_URL=
NEXFIT_API_KEY=

# Asaas → tenant_config key: asaas.api_key
ASAAS_API_URL=
ASAAS_API_KEY=

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────
FEATURE_INSTAGRAM_ENABLED=false
FEATURE_TIKTOK_ENABLED=false
FEATURE_MESSENGER_ENABLED=false
